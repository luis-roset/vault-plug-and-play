# ============================================================
# SECRETS & CREDENTIALS — never commit these
# ============================================================

# Vault Enterprise license
vault.hclic
*.hclic

# Vault init output (unseal keys + root token)
.vault-init
**/.vault-init

# Vault / Prometheus tokens
prometheus-token
prometheus-config/prometheus-token

# HCP / Vault Radar secrets file
Vault-Radar/Vault_Radar_Agent.txt

# ============================================================
# VAULT RUNTIME DATA
# ============================================================

# Vault storage data
Prometheus/vault-data/
**/vault-data/

# Raft data (tech-link already ignores /raft, but cover root level too)
raft/
**/raft/

# ============================================================
# TLS CERTIFICATES & KEYS
# ============================================================

*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
Vault-Radar/tls/

# ============================================================
# DATABASE DATA
# ============================================================

tech-link/postgres-data/
**/postgres-data/

# ============================================================
# OS / EDITOR NOISE
# ============================================================

.DS_Store
**/.DS_Store
Thumbs.db

# ============================================================
# ENV FILES (catch-all for any future secrets)
# ============================================================

.env
.env.*
*.env
