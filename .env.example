# =============================================================================
# Vault Enterprise — Environment Configuration
# Copy this file to .env and fill in the values.
# Variables set here are loaded automatically by deploy.sh.
# =============================================================================

# Vault Enterprise image version.
# Examples: latest, 1.18.4, 1.17.6
# If a bare version number is given (e.g. 1.18.4), the "-ent" suffix is
# appended automatically.
# VAULT_VERSION=latest

# Number of nodes to deploy: 1 or 2.
# Selecting 2 creates a second node and configures Performance Replication
# between them (node1 = primary, node2 = secondary).
# NODE_COUNT=1

# Vault Enterprise License (required).
# Obtain a license from https://www.hashicorp.com/products/vault/trial
# Paste the full license string (begins with "02MV4AA...").
# VAULT_LICENSE="<your-license-string-here>"
