
# deny-admin-kv2-plaintext-read.sentinel

is_kv2_plaintext_read = rule {
  request.operation is "read" and
  request.path matches "^(.*/)?[^/]+/data/.+$"
}

is_admin_token = rule {
  "admin" in token.policies
}

main = rule when not request.unauthenticated {
  not (is_admin_token and is_kv2_plaintext_read)
}