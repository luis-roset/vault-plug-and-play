<form version="1.1">
  <label>Where are high TTL tokens created?</label>
  <fieldset submitButton="false">
    <input type="time" token="timerange" searchWhenChanged="true">
      <label>Time span</label>
      <default>
        <earliest>-7d@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="cluster" searchWhenChanged="true">
      <label>Cluster</label>
      <default>*</default>
      <fieldForLabel>cluster</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query>| mcatalog values(cluster) as value WHERE `vault_telemetry` by cluster</query>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </search>
      <choice value="*">all</choice>
    </input>
    <input type="dropdown" token="namespace" searchWhenChanged="true">
      <label>Namespace</label>
      <default>*</default>
      <initialValue>*</initialValue>
      <fieldForLabel>namespace</fieldForLabel>
      <fieldForValue>namespace_path</fieldForValue>
      <search>
        <query>| mcatalog values(namespace) AS namespace_path WHERE `vault_telemetry` AND cluster=$cluster$ BY namespace</query>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </search>
      <choice value="*">All</choice>
      <change>
        <condition label="All">
          <set token="namespace_filter">where 1==1</set>
        </condition>
        <condition match="len($namespace$) &gt; 0">
          <set token="namespace_filter">where namespace=="$namespace$"</set>
        </condition>
      </change>
    </input>
    <input type="dropdown" token="creation_ttl" searchWhenChanged="true">
      <label>Creation TTL</label>
      <choice value="1m">&lt;= 1  minute</choice>
      <choice value="10m">1-10 minutes</choice>
      <choice value="20m">10-20 minutes</choice>
      <choice value="1h">20m-1 hour</choice>
      <choice value="2h">1-2 hours</choice>
      <choice value="1d">2h- 1 day</choice>
      <choice value="2d">1-2 days</choice>
      <choice value="7d">2-7 days</choice>
      <choice value="30d">7-30 days</choice>
      <choice value="+Inf">longer than 30 days</choice>
      <default>+Inf</default>
      <change>
        <condition value="1m">
          <set token="creation_ttl_filter">("response.auth.token_ttl" &lt;= 60)</set>
        </condition>
        <condition value="10m">
          <set token="creation_ttl_filter">(response.auth.token_ttl &lt;= 600 AND response.auth.token_ttl &gt; 60)</set>
        </condition>
        <condition value="20m">
          <set token="creation_ttl_filter">(response.auth.token_ttl &lt;= 1200 AND response.auth.token_ttl &gt; 600)</set>
        </condition>
        <condition value="1h">
          <set token="creation_ttl_filter">(response.auth.token_ttl &lt;= 3600 AND response.auth.token_ttl &gt; 1200)</set>
        </condition>
        <condition value="2h">
          <set token="creation_ttl_filter">(response.auth.token_ttl &lt;= 7200 AND response.auth.token_ttl &gt; 3600)</set>
        </condition>
        <condition value="1d">
          <set token="creation_ttl_filter">(response.auth.token_ttl &lt;= 86400 AND response.auth.token_ttl &gt; 7200)</set>
        </condition>
        <condition value="2d">
          <set token="creation_ttl_filter">(response.auth.token_ttl &lt;= 172800 AND response.auth.token_ttl &gt; 86400)</set>
        </condition>
        <condition value="7d">
          <set token="creation_ttl_filter">(response.auth.token_ttl &lt;= 604800 AND response.auth.token_ttl &gt; 172800)</set>
        </condition>
        <condition value="30d">
          <set token="creation_ttl_filter">(response.auth.token_ttl &lt;= 2592000 AND response.auth.token_ttl &gt; 604800)</set>
        </condition>
        <condition value="+Inf">
          <set token="creation_ttl_filter">(response.auth.token_ttl &gt; 2592000)</set>
        </condition>
      </change>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Tokens by mount point, for creation TTL $creation_ttl$</title>
      <chart>
        <search>
          <query>| mstats sum(vault.token.creation.value) AS count WHERE `vault_telemetry` AND cluster=$cluster$ AND creation_ttl=$creation_ttl$ AND namespace=$namespace$ BY cluster,namespace,mount_point
| sort - count
| head 12
| eval namespace=if(namespace=="root","",namespace)
| strcat namespace "/" mount_point path
| table path, count</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.drilldown">none</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Tokens by path and IP address, for creation TTL $creation_ttl$</title>
      <table>
        <search>
          <query>`vault_audit_log` cluster=$cluster$ response.auth.accessor="*" $creation_ttl_filter$
| eval namespace_id=json_extract(_raw,"request.namespace.id")
| eval namespace_path=json_extract(_raw,"request.namespace.path")
| eval namespace=if(namespace_id=="root", "root", replace( namespace_path, "/$", "" ))
| $namespace_filter$
| stats count by cluster, namespace, request.path, request.remote_address
| sort -count
| head 12</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
        </search>
        <option name="count">10</option>
        <option name="drilldown">none</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>Tokens by display name, for creation TTL $creation_ttl$</title>
      <table>
        <search>
          <query>`vault_audit_log` cluster=$cluster$ response.auth.accessor="*" $creation_ttl_filter$
`vault_audit_log` cluster=$cluster$ response.auth.accessor="*" $creation_ttl_filter$
| eval namespace_id=json_extract(_raw,"request.namespace.id")
| eval namespace_path=json_extract(_raw,"request.namespace.path")
| eval namespace=if(namespace_id=="root", "root", replace( namespace_path, "/$", "" ))
| $namespace_filter$
| stats count by cluster, response.auth.display_name
| sort -count
| head 12</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
        </search>
        <option name="count">10</option>
        <option name="drilldown">none</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>Token creation audit log entries</title>
      <event>
        <search>
          <query>`vault_audit_log` cluster=$cluster$ response.auth.accessor="*" $creation_ttl_filter$
| eval namespace_id=json_extract(_raw,"request.namespace.id")
| eval namespace_path=json_extract(_raw,"request.namespace.path")
| eval namespace=if(namespace_id=="root", "root", replace( namespace_path, "/$", "" ))
| $namespace_filter$</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
        </search>
        <option name="list.drilldown">none</option>
        <option name="refresh.display">progressbar</option>
      </event>
    </panel>
  </row>
</form>
