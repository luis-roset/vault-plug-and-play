<form version="1.1">
  <label>Summary</label>
  <fieldset submitButton="false">
    <input type="time" token="timerange" searchWhenChanged="true">
      <label>Time span</label>
      <default>
        <earliest>-7d@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="cluster" searchWhenChanged="true">
      <label>Cluster</label>
      <default>*</default>
      <fieldForLabel>cluster</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query>| mcatalog values(cluster) as value WHERE `vault_telemetry` by cluster</query>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </search>
      <choice value="*">all</choice>
    </input>
    <input type="dropdown" token="storage_type" searchWhenChanged="true">
      <label>Storage Type</label>
      <choice>Integrated Storage</choice>
      <choice>Consul</choice>
      <default>Integrated Storage</default>
      <change>
        <condition value="Integrated Storage">
          <set token="storage_type_is_raft">true</set>
          <unset token="storage_type_is_consul"></unset>
        </condition>
        <condition value="Consul">
          <unset token="storage_type_is_raft"></unset>
          <set token="storage_type_is_consul">true</set>
        </condition>
      </change>
    </input>
  </fieldset>
  <row>
    <panel>
      <html>
        <style>
          .dashboard-row .dashboard-panel .panel-body.html {
            background: #f2f4f5;
            padding-top: 20px;
            padding-bottom: 0;
          }
        </style>
        <a class="btn btn-primary pull-right" style="background-color: #1563ff;" href="vault_operations_from_telemetry">View more ›</a>
        <h2>Vault Operations Metrics from Telemetry</h2>
      </html>
    </panel>
  </row>
  <row>
    <panel>
      <title>Seal Status</title>
      <table>
        <search>
          <query>| mstats latest(vault.core.unsealed.value) AS raw WHERE `vault_telemetry` AND cluster=$cluster$ BY host 
| sort raw, host
| eval seal_status=case(raw==0.0, "Sealed", raw==1.0, "Unsealed")
| fields host,seal_status</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="count">10</option>
        <option name="drilldown">none</option>
        <option name="refresh.display">progressbar</option>
        <format type="color" field="seal_status">
          <colorPalette type="map">{"Unsealed":#53A051,"Sealed":#DC4E41}</colorPalette>
        </format>
      </table>
    </panel>
    <panel>
      <title>User CPU % (max over all hosts)</title>
      <chart>
        <search>
          <!-- cpu.user_cpu -->
          <query>| mstats max(cpu.usage_user) as user WHERE `vault_telemetry` AND cluster=$cluster$ AND cpu=cpu-total span=1m
| timechart bins=1000 mean(user) as cpu 
| eventstats perc90(cpu) perc50(cpu)</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">% (mean)</option>
        <option name="charting.axisTitleY.visibility">visible</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"cpu":0x1563ff, "perc90(cpu)":0x888888, "perc50(cpu)":0x888888}</option>
        <option name="charting.fieldDashStyles">{"perc90(cpu)":"dot","perc50(cpu)":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">200</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
    <panel>
      <title>Percent of memory in use (max over all hosts)</title>
      <chart>
        <search>
          <!-- mem.used_percent -->
          <query>| mstats max(mem.used_percent) as mem WHERE `vault_telemetry` AND cluster=$cluster$ span=1m
| timechart bins=1000 mean(mem) as mem
| eventstats perc90(mem) perc50(mem)</query>
          <earliest>-7d@d</earliest>
          <latest>now</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">% (mean)</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"mem":0x1563ff, "perc90(mem)":0x888888, "perc50(mem)":0x888888}</option>
        <option name="charting.fieldDashStyles">{"perc90(mem)":"dot","perc50(mem)":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">200</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
    <panel>
      <title>Network IO (max over all hosts)</title>
      <chart>
        <search>
          <!-- net.bytes_recv and net.bytes.sent-->
          <query>| mstats rate(net.bytes_recv) as recv_raw, rate(net.bytes_sent) as sent_raw WHERE `vault_telemetry` AND cluster=$cluster$ by host,interface span=1m
| eval total = recv_raw + sent_raw
| stats sum(total) as total by host,_time
| stats max(total) as total by _time
| timechart bins=1000 avg(total) as total
| eventstats perc90(total) perc50(total)</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">bytes/s (mean)</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"total":0x1563ff, "perc90(total)":0x888888, "perc50(total)":0x888888}</option>
        <option name="charting.fieldDashStyles">{"perc90(total)":"dot","perc50(total)":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">200</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
    <panel>
      <title>Request handling time</title>
      <chart>
        <search>
          <!-- vault.core.handle_request -->
          <query>| mstats mean(vault.core.handle_request.mean) as latency where `vault_telemetry` AND cluster=$cluster$ span=1m
| timechart bins=1000 mean(latency) as latency
| eventstats perc90(latency) perc50(latency)</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">ms (mean)</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"latency":0x1563ff, "perc90(latency)":0x888888, "perc50(latency)":0x888888}</option>
        <option name="charting.fieldDashStyles">{"perc90(latency)":"dot","perc50(latency)":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">200</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <html>
        <a class="btn btn-primary pull-right" style="background-color: #1563ff;" href="vault_usage_from_telemetry">View more ›</a>
        <h2>Vault Usage from Telemetry</h2>
      </html>
    </panel>
  </row>
  <row>
    <panel>
      <title>Latest number of tokens</title>
      <single>
        <search>
          <!-- vault.audit.log_request_failure -->
          <query>| mstats latest(vault.token.count.value) as count where `vault_telemetry` AND cluster=$cluster$ by cluster, namespace span=1h 
| stats sum(count) as count by _time
| sort _time 
| tail 1 
| table count</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="height">200</option>
        <option name="rangeColors">["0x53a051","0x0877a6","0xf8be34","0xf1813f","0xdc4e41"]</option>
        <option name="refresh.display">progressbar</option>
        <option name="showTrendIndicator">0</option>
        <option name="underLabel">Tokens</option>
      </single>
    </panel>
    <panel>
      <title>Tokens created per hour</title>
      <chart>
        <search>
          <!-- mem.used_percent -->
          <query>|  mstats sum(vault.token.creation.value) as count where `vault_telemetry` AND cluster=$cluster$ span=1h 
|  timechart sum(count) as count span=1h
|  fillnull value=0
|  eventstats perc90(count) perc50(count)</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>30m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">tokens</option>
        <option name="charting.axisTitleY.visibility">collapsed</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"count":0x1563ff, "perc90(count)":0x888888, "perc50(count)":0x888888}</option>
        <option name="charting.fieldDashStyles">{"perc90(count)":"dot","perc50(count)":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">200</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <title>Identity Entities created per hour</title>
      <chart>
        <search>
          <!-- vault.identity.entity.count -->
          <!-- Filters by cluster, namespace -->
          <query>|  mstats sum(vault.identity.entity.creation.value) as count where `vault_telemetry` AND cluster=$cluster$ span=1h 
|  timechart sum(count) as count span=1h
|  fillnull value=0
|  eventstats perc90(count) perc50(count)</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>30m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"count":0x1563ff, "perc90(count)":0x888888, "perc50(count)":0x888888}</option>
        <option name="charting.fieldDashStyles">{"perc90(count)":"dot","perc50(count)":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">200</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <title>Identity Entities count</title>
      <chart>
        <search>
          <!-- vault.identity.entity.creation -->
          <!-- Filters by cluster, namespace, auth_method, mount_point, auth_entity -->
          <query>|  mstats latest(vault.identity.entity.count.value) as count where `vault_telemetry` AND cluster=$cluster$ by cluster, namespace span=1h
| stats sum(count) as count by _time</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>10m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.visibility">collapsed</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"count":0x1563ff, "perc90(count)":0x888888, "perc50(count)":0x888888}</option>
        <option name="charting.fieldDashStyles">{"perc90(count)":"dot","perc50(count)":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">200</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <title>Tokens by TTL</title>
      <chart id="tokens_by_ttl">
        <search>
          <query>| mstats latest(vault.token.count.by_ttl.value) as count where `vault_telemetry` AND cluster=$cluster$ by cluster,namespace,creation_ttl span=1h
| stats sum(count) as count by _time,creation_ttl
| eventstats latest(_time) as latesttime
| where _time == latesttime
| stats max(count) as count by creation_ttl</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>10m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <!-- vault.token.count.by_ttl (Number of existing tokens, aggregated by their TTL at creation.) -->
        <option name="charting.chart">pie</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="height">200</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <html>
        <a class="btn btn-primary pull-right" style="background-color: #1563ff;" href="vault_usage_from_audit_logs">View more ›</a>
        <h2>Vault Usage from Audit Logs</h2>
        <!-- TODO: The data on this page don't seem to match the original list. Which ones are correct? -->
      </html>
    </panel>
  </row>
  <row>
    <panel>
      <title>Tokens by auth type</title>
      <chart id="tokens_by_auth_type">
        <search>
          <!-- vault.token.count.by_auth (Number of existing tokens broken down by auth method used to create them) -->
          <query>| mstats latest(vault.token.count.by_auth.value) as count where `vault_telemetry` AND cluster=$cluster$ by cluster,namespace,auth_method span=1h
| stats sum(count) as count by _time, auth_method
| eventstats latest(_time) as latesttime
| where _time == latesttime
| stats max(count) as count by auth_method</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>10m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="height">200</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <title>Active tokens by auth method</title>
      <chart id="active_tokens_by_auth_method">
        <search>
          <!-- vault.token.count.by_auth (Number of existing tokens broken down by auth method used to create them) -->
          <query>`vault_audit_log` type=request cluster=$cluster$
| stats count by auth.accessor
| join auth.accessor
 [search `vault_audit_log` type=response response.auth.accessor=* cluster=$cluster$
    |  table response.auth.accessor, response.mount_type
    |  rename response.mount_type as auth_method
    |  rename response.auth.accessor as auth.accessor
    | append
        [search `vault_audit_log` type=request cluster=$cluster$
        | table auth.accessor
        | dedup auth.accessor
        | eval auth_method="unknown"]
    | dedup auth.accessor ]
| stats count by auth_method</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>10m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="height">200</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <title>Secret leases created, by authentication method of token</title>
      <chart id="leases_by_auth_method">
        <search>
          <!-- vault.token.count.by_auth (Number of existing tokens broken down by auth method used to create them) -->
          <query>`vault_audit_log` type=response response.secret.lease_id=* cluster=$cluster$
| stats count by auth.accessor
| join auth.accessor
 [search `vault_audit_log` type=response response.auth.accessor=* cluster=$cluster$
    |  table response.auth.accessor, response.mount_type
    |  rename response.mount_type as auth_method
    |  rename response.auth.accessor as auth.accessor
    | append
        [search `vault_audit_log` type=request cluster=$cluster$
        | table auth.accessor
        | dedup auth.accessor
        | eval auth_method="unknown"]
    | dedup auth.accessor ]
| stats sum(count) as count by auth_method</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>10m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="height">200</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <title>Requests by Entity</title>
      <chart id="requests_by_entity">
        <search>
          <!-- vault.token.count.by_auth (Number of existing tokens broken down by auth method used to create them) -->
          <query>`vault_audit_log` type="request" cluster=$cluster$
| stats count by auth.entity_id 
| append 
    [ search `vault_audit_log` type="request" cluster=$cluster$ AND NOT auth.entity_id ="*"
    |  stats count
    | eval auth.entity_id="none" ]
| sort - count</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>10m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="height">200</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <html>
        <a class="btn btn-primary pull-right" style="background-color: #1563ff;" href="vault_storage">View more ›</a>
        <h2>Vault Storage Metrics ($storage_type$)</h2>
      </html>
    </panel>
  </row>
  <row depends="$storage_type_is_raft$">
    <panel>
      <title>Duration of a LIST operation</title>
      <chart>
        <search>
          <!-- vault.raft-storage.list -->
          <query>| mstats latest(vault.raft-storage.list.mean) as latency where `vault_telemetry` AND cluster=$cluster$ span=1m
| timechart bins=1000 mean(latency) as latency
| eventstats perc90(latency) perc50(latency)</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">ms (mean)</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"latency":0x1563ff, "perc90(latency)":0x888888, "perc50(latency)":0x888888}</option>
        <option name="charting.fieldDashStyles">{"perc90(latency)":"dot","perc50(latency)":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
    <panel>
      <title>Duration of a GET operation</title>
      <chart>
        <search>
          <!-- vault.raft-storage.list -->
          <query>| mstats latest(vault.raft-storage.get.mean) as latency where `vault_telemetry` AND cluster=$cluster$ span=1m
| timechart bins=1000 mean(latency) as latency
| eventstats perc90(latency) perc50(latency)</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
