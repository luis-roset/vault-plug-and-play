<form version="1.1">
  <label>Quota monitoring</label>
  <fieldset submitButton="false" autoRun="false">
    <input type="time" token="timerange" searchWhenChanged="true">
      <label>Time</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="quota_name" searchWhenChanged="true">
      <label>Quota name</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>name</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query>| mcatalog values(name) AS value WHERE metric_name=vault.quota.* AND cluster=* BY name</query>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </search>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Rate limit violations</title>
      <chart>
        <title>by quota name</title>
        <search>
          <query>| mstats sum(vault.quota.rate_limit.violation.value) AS violations WHERE `vault_telemetry` AND name=$quota_name$ BY name span=1m
| timechart bins=1000 sum(violations) BY name</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">-45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.visibility">collapsed</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.drilldown">none</option>
        <option name="height">200</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Lease count violations</title>
      <chart>
        <title>by quota name</title>
        <search>
          <query>| mstats sum(vault.quota.lease_count.violation.value) AS violations WHERE `vault_telemetry` AND name=$quota_name$ BY name span=1m
| timechart bins=1000 sum(violations) BY name</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">-45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.visibility">collapsed</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.drilldown">none</option>
        <option name="height">200</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <title>Lease count utilization</title>
      <chart>
        <title>by quota name</title>
        <search>
          <query>| mstats max(vault.quota.lease_count.max.value) AS limit latest(vault.quota.lease_count.counter.value) AS current WHERE `vault_telemetry` AND name=$quota_name$ BY name span=1m
| eval percent = current / limit * 100.0
| timechart bins=1000 max(percent) BY name</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">-45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">%</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.drilldown">none</option>
        <option name="height">200</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
</form>
