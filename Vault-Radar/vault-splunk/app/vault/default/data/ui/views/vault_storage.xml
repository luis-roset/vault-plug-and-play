<form version="1.1">
  <label>Vault Storage Metrics</label>
  <description>Filters</description>
  <search id="clientTokens">
    <query>`vault_audit_log` request.namespace.id=$namespace_id$| fields auth.client_token auth.token_type response.auth.display_name auth.display_name response.secret.lease_id request.path _time</query>
    <earliest>$timerange.earliest$</earliest>
    <latest>$timerange.latest$</latest>
  </search>
  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="timerange" searchWhenChanged="true">
      <label>Time Span</label>
      <default>
        <earliest>-7d@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="cluster" searchWhenChanged="true">
      <label>Cluster</label>
      <default>*</default>
      <fieldForLabel>cluster</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query>| mcatalog values(cluster) as value WHERE `vault_telemetry` by cluster</query>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </search>
      <choice value="*">all</choice>
    </input>
    <input type="dropdown" token="storage_type" searchWhenChanged="true">
      <label>Storage Type</label>
      <choice>Integrated Storage</choice>
      <choice>Consul</choice>
      <default>Integrated Storage</default>
      <change>
        <condition value="Integrated Storage">
          <set token="storage_type_is_raft">true</set>
          <unset token="storage_type_is_consul"></unset>
        </condition>
        <condition value="Consul">
          <unset token="storage_type_is_raft"></unset>
          <set token="storage_type_is_consul">true</set>
        </condition>
      </change>
    </input>
    <input type="multiselect" token="hostfilter">
      <label>Host</label>
      <choice value="*">all</choice>
      <prefix>(</prefix>
      <suffix>)</suffix>
      <initialValue>*</initialValue>
      <valuePrefix>host=</valuePrefix>
      <delimiter> OR </delimiter>
      <fieldForLabel>host</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query>| mcatalog values(host) as value WHERE `vault_telemetry` AND cluster=$cluster$ by host</query>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </search>
    </input>
  </fieldset>
  <row>
    <panel>
      <html>
        <h2>Vault Storage Metrics</h2>
      </html>
    </panel>
  </row>
  <row depends="$storage_type_is_raft$">
    <panel>
      <title>Duration of a LIST operation</title>
      <chart>
        <search>
          <query>| mstats latest(vault.raft-storage.list.mean) as latency where `vault_telemetry` AND cluster=$cluster$ span=1m
| timechart bins=1000 mean(latency) as latency
| eventstats perc90(latency) perc50(latency)</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">ms (mean)</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"latency":0x1563ff, "perc90(latency)":0x888888, "perc50(latency)":0x888888}</option>
        <option name="charting.fieldDashStyles">{"perc90(latency)":"dot","perc50(latency)":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
    <panel>
      <title>Duration of a GET operation</title>
      <chart>
        <search>
          <query>| mstats latest(vault.raft-storage.get.mean) as latency where `vault_telemetry` AND cluster=$cluster$ span=1m
| timechart bins=1000 mean(latency) as latency
| eventstats perc90(latency) perc50(latency)</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">ms (mean)</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"latency":0x1563ff, "perc90(latency)":0x888888, "perc50(latency)":0x888888}</option>
        <option name="charting.fieldDashStyles">{"perc90(latency)":"dot","perc50(latency)":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
    <panel>
      <title>Duration of a PUT operation</title>
      <chart>
        <search>
          <query>| mstats latest(vault.raft-storage.put.mean) as latency where `vault_telemetry` AND cluster=$cluster$ span=1m
| timechart bins=1000 mean(latency) as latency
| eventstats perc90(latency) perc50(latency)</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">ms (mean)</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"latency":0x1563ff, "perc90(latency)":0x888888, "perc50(latency)":0x888888}</option>
        <option name="charting.fieldDashStyles">{"perc90(latency)":"dot","perc50(latency)":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
    <panel>
      <title>Duration of a DELETE operation</title>
      <chart>
        <search>
          <query>| mstats latest(vault.raft-storage.delete.mean) as latency where `vault_telemetry` AND cluster=$cluster$ span=1m
| timechart bins=1000 mean(latency) as latency
| eventstats perc90(latency) perc50(latency)</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">ms (mean)</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"latency":0x1563ff, "perc90(latency)":0x888888, "perc50(latency)":0x888888}</option>
        <option name="charting.fieldDashStyles">{"perc90(latency)":"dot","perc50(latency)":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
  </row>
  <row depends="$storage_type_is_raft$">
    <panel>
      <title>Number of integrated storage operations by type</title>
      <chart>
        <search>
          <query>| mstats sum(vault.raft-storage.*.count) as * where `vault_telemetry` AND cluster=$cluster$ span=1m
| fields list,get,put,delete,transaction
| timechart bins=1000 sum(*) AS *</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.drilldown">none</option>
        <option name="refresh.display">progressbar</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
      </chart>
    </panel>
    <panel>
      <title>Entry size per integrated storage operation</title>
      <chart>
        <search>
          <query>| mstats mean(vault.raft-storage.entry_size.mean) as mean_size, max(vault.raft-storage.entry_size.upper) as max_size where `vault_telemetry` AND cluster=$cluster$ span=1m
| eventstats max(max_size) AS largest
| timechart bins=1000 mean(mean_size) as mean_size_in_interval, max(max_size) as max_size_in_interval, max(largest) as max_size</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">bytes</option>
        <option name="charting.axisY.abbreviation">auto</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"max_size_in_interval":0x1563ff, "mean_size_in_interval":0x25BA81, "max_size":0x555555 }</option>
        <option name="charting.fieldDashStyles">{"max_size":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
  </row>
