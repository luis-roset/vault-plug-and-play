  <row>
    <panel>
      <html>
        <h2>Host I/O Metrics</h2>
      </html>
    </panel>
  </row>
  <row>
    <panel depends="$storage_type_is_raft$">
      <title>Disk IO</title>
      <chart>
        <title>Sum over all devices</title>
        <search>
          <query>| mstats rate(diskio.read_bytes) AS read rate(diskio.write_bytes) AS write WHERE `vault_telemetry` AND cluster=$cluster$ AND $hostfilter$ BY host,name span=5m
| stats sum(read) AS read, sum(write) AS write by _time,host
| timechart mean(read) as read, mean(write) as write bins=1000 by host</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">bytes/s (mean)</option>
        <option name="charting.axisY.abbreviation">auto</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
    <panel depends="$storage_type_is_raft$">
      <title>Disk usage</title>
      <chart>
        <search>
          <query>| mstats latest(disk.used_percent) AS raw_pct WHERE `vault_telemetry` AND $hostfilter$ AND cluster=$cluster$ BY device, host  span=10m
| strcat host ":" device label
| eval rounded_pct=round(raw_pct,2)
| timechart bins=300 latest(rounded_pct) by label</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>10m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">% (latest)</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.drilldown">none</option>
        <option name="refresh.display">progressbar</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
      </chart>
    </panel>
    <panel>
      <title>Network IO</title>
      <chart>
        <title>Sum over all interfaces</title>
        <search>
          <query>| mstats rate(net.bytes_recv) as recv, rate(net.bytes_sent) as sent WHERE `vault_telemetry` AND cluster=$cluster$ AND $hostfilter$ BY host,interface span=1m
| stats sum(recv) AS recv, sum(sent) AS sent BY _time,host
| timechart mean(recv) as recv, mean(sent) as sent bins=1000 BY host</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">bytes/s (mean)</option>
        <option name="charting.axisY.abbreviation">auto</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
  </row>
</form>
