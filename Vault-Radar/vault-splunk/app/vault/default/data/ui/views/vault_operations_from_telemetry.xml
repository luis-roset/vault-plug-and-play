<form version="1.1">
  <label>Vault Operations Metrics from Telemetry</label>
  <description>Operational metrics</description>
  <!-- Filters -->
  <fieldset submitButton="false">
    <input type="time" token="timerange" searchWhenChanged="true">
      <label>Time span</label>
      <default>
        <earliest>-7d@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="cluster" searchWhenChanged="true">
      <label>Cluster</label>
      <choice value="*">all</choice>
      <fieldForLabel>cluster</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query>| mcatalog values(cluster) as value WHERE `vault_telemetry` by cluster</query>
      </search>
      <initialValue>*</initialValue>
    </input>
    <input type="multiselect" token="hostfilter">
      <label>Host</label>
      <choice value="*">all</choice>
      <prefix>(</prefix>
      <suffix>)</suffix>
      <initialValue>*</initialValue>
      <valuePrefix>host=</valuePrefix>
      <delimiter> OR </delimiter>
      <fieldForLabel>host</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query>| mcatalog values(host) as value WHERE `vault_telemetry` AND cluster=$cluster$ by host</query>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </search>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Seal Status (self-reported from Vault)</title>
      <table>
        <search>
          <query>| mstats latest(vault.core.unsealed.value) AS raw WHERE `vault_telemetry` AND cluster=$cluster$ AND $hostfilter$ BY host 
| sort raw, host
| eval seal_status=case(raw==0.0, "Sealed", raw==1.0, "Unsealed")
| fields host,seal_status</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
        </search>
        <option name="count">10</option>
        <option name="drilldown">none</option>
        <option name="refresh.display">progressbar</option>
        <format type="color" field="seal_status">
          <colorPalette type="map">{"Unsealed":#53A051,"Sealed":#DC4E41}</colorPalette>
        </format>
      </table>
    </panel>
    <panel>
      <title>Disk IO</title>
      <chart>
        <title>Sum over all devices</title>
        <search>
          <!-- diskio.read_bytes -->
          <!-- diskio.write_bytes  -->
          <query>| mstats rate(diskio.read_bytes) AS read rate(diskio.write_bytes) AS write WHERE `vault_telemetry` AND cluster=$cluster$ AND $hostfilter$ BY host,name span=5m
| stats sum(read) AS read, sum(write) AS write by _time,host
| timechart max(read) as read, max(write) as write bins=1000 by host</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">peak bytes/s</option>
        <option name="charting.axisY.abbreviation">auto</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
    <panel>
      <title>Network IO</title>
      <chart>
        <title>Sum over all interfaces</title>
        <search>
          <!-- net.bytes_recv -->
          <!-- net.bytes_sent // TODO: Add this line to chart -->
          <query>| mstats rate(net.bytes_recv) as recv, rate(net.bytes_sent) as sent WHERE `vault_telemetry` AND cluster=$cluster$ AND $hostfilter$ BY host,interface span=1m 
| stats sum(recv) as recv, sum(sent) as sent by _time, host
| timechart max(recv) as recv, max(sent) as sent bins=1000 BY host</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">peak bytes/s</option>
        <option name="charting.axisY.abbreviation">auto</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Percent of CPU used</title>
      <chart>
        <search>
          <!-- cpu.user_cpu -->
          <query>| mstats max(cpu.usage_user) as user WHERE `vault_telemetry` AND cluster=$cluster$ AND $hostfilter$ AND cpu=cpu-total BY host span=1m
| timechart max(user) bins=1000 by host</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">%</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="charting.fieldColors">{"warning":0x8d9113, "critical":0x7f0000}</option>
        <option name="charting.fieldDashStyles">{"warning":"dot","critical":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
    <panel>
      <title>Percent of CPU time waiting for tasks to complete</title>
      <chart>
        <search>
          <!-- cpu.iowait_cpu -->
          <query>| mstats max(cpu.usage_iowait) as iowait WHERE `vault_telemetry` AND cluster=$cluster$ AND $hostfilter$ AND cpu=cpu-total BY host span=1m
| timechart max(iowait) AS iowait bins=1000 BY host
| eval critical=10.0</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">%</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="charting.fieldColors">{"warning":0x8d9113, "critical":0x7f0000}</option>
        <option name="charting.fieldDashStyles">{"warning":"dot","critical":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
    <panel>
      <title>Time taken by stop-the-world garbage collection pauses</title>
      <chart>
        <search>
          <!-- vault.runtime.total_gc_pause_ns -->
          <query>| mstats rate(vault.runtime.total_gc_pause_ns.value) as gc_pause WHERE `vault_telemetry` AND cluster=$cluster$ AND $hostfilter$ BY host span=5m
| timechart max(gc_pause) AS iowait bins=1000 BY host
| eval warning=3.3e7, critical=8.3e7</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">ns</option>
        <option name="charting.axisY.abbreviation">auto</option>
        <option name="charting.axisY.scale">log</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"warning":0x8d9113, "critical":0x7f0000}</option>
        <option name="charting.fieldDashStyles">{"warning":"dot","critical":"dot"}</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <html>
        <style>
          .dashboard-row .dashboard-panel .panel-body.html {
            background: #f2f4f5;
            padding-top: 20px;
            padding-bottom: 0;
          }
        </style>
        <h2>Requests</h2>
      </html>
    </panel>
  </row>
  <row>
    <panel>
      <title>Request handle time</title>
      <chart>
        <search>
          <!-- vault.core.handle_request -->
          <query>| mstats mean(vault.core.handle_request.mean) as latency where `vault_telemetry` AND cluster=$cluster$ span=1m
| timechart bins=1000 mean(latency) as latency
| eventstats perc90(latency) perc50(latency)</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">ms</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"latency":0x1563ff, "perc90(latency)":0x888888, "perc50(latency)":0x888888}</option>
        <option name="charting.fieldDashStyles">{"perc90(latency)":"dot","perc50(latency)":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
    <panel>
      <title>Login request handle time</title>
      <chart>
        <search>
          <!-- vault.core.handle_login_request -->
          <query>| mstats mean(vault.core.handle_login_request.mean) as latency where `vault_telemetry` AND cluster=$cluster$ span=1m
| timechart bins=1000 mean(latency) as latency
| eventstats perc90(latency) perc50(latency)</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">ms</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"latency":0x1563ff, "perc90(latency)":0x888888, "perc50(latency)":0x888888}</option>
        <option name="charting.fieldDashStyles">{"perc90(latency)":"dot","perc50(latency)":"dot"}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <html>
        <h2>Audit Logs</h2>
      </html>
    </panel>
  </row>
  <row>
    <panel>
      <title>Audit log failures</title>
      <single>
        <search>
          <!-- vault.audit.log_request_failure -->
          <query>| mstats sum(vault.audit.log_request_failure.value) WHERE `vault_telemetry` AND cluster=$cluster$</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="rangeColors">["0x53a051","0x0877a6","0xf8be34","0xf1813f","0xdc4e41"]</option>
        <option name="refresh.display">progressbar</option>
        <option name="showTrendIndicator">0</option>
        <option name="underLabel">Request failures</option>
        <option name="height">200</option>
      </single>
      <single>
        <search>
          <query>| mstats sum(vault.audit.log_response_failure.value) WHERE `vault_telemetry` AND cluster=$cluster$</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="rangeColors">["0x53a051","0x0877a6","0xf8be34","0xf1813f","0xdc4e41"]</option>
        <option name="refresh.display">progressbar</option>
        <option name="showTrendIndicator">0</option>
        <option name="underLabel">Response failures</option>
        <option name="height">200</option>
      </single>
    </panel>
  </row>
  <row>
    <panel>
      <html>
        <h2>Leadership</h2>
      </html>
    </panel>
  </row>
  <row>
    <panel>
      <title>Core leadership losses</title>
      <chart>
        <search>
          <!-- vault.core.leadership_lost -->
          <query>| mstats sum(vault.core.leadership_lost.count) as count where `vault_telemetry` AND cluster=$cluster$ span=1m
| timechart bins=1000 sum(count) AS count</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.fieldColors">{"count":0x1563ff}</option>
        <option name="charting.layout.splitSeries">0</option>
