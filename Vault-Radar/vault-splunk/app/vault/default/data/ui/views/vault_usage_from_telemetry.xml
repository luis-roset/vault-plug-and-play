  <row depends="$show_mount_point_timeseries$">
    <panel>
      <title>$token_type_title$ created$namespace_title$$auth_method_title$$creation_ttl_title$</title>
      <chart>
        <title>By mount point</title>
        <search>
          <!-- vault.token.creation -->
          <!-- Filters by cluster, namespace, auth_method, mount_point, creation_ttl, auth_entity, policies, token type -->
          <query>| mstats sum(vault.token.creation.value) AS tokens WHERE `vault_telemetry` AND cluster=$cluster$ AND namespace IN ($namespace_list$) AND mount_point IN ($mount_point_list$) AND auth_method IN ($auth_method_list$) AND creation_ttl IN ($creation_ttl_list$) AND token_type=$token_type$ BY mount_point span=1m
