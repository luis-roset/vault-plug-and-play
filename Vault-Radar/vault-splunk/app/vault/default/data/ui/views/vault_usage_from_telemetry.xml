      <chart>
        <search>
          <query>| mstats sum(vault.route.*.count) AS raw_count.* where `vault_telemetry` AND cluster=* BY metric_name
| eval temp=split(metric_name, "."), operation=mvindex(temp,2), mount=mvindex(temp,3)
