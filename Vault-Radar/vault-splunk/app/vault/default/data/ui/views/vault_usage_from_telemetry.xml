| foreach raw_count* 
    [eval count=coalesce(count,'&lt;&lt;FIELD&gt;&gt;')]
| eval slash_mount=replace(mount,"-","/")
| strcat slash_mount ":" operation path
| sort -count
| head 15
| table path,count</query>
