<form version="1.1">
  <label>Vault Usage Metrics from Telemetry</label>
  <!-- time series per namespace  -->
  <!-- time series per auth method  -->
  <!-- time series per mount point  -->
  <!-- time series per policy  -->
  <!-- time series per ttl bucket  -->
  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="timerange" searchWhenChanged="true">
      <label>Time span</label>
      <default>
        <earliest>-7d@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="cluster" searchWhenChanged="true">
      <label>Cluster</label>
      <default>*</default>
      <fieldForLabel>cluster</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query>| mcatalog values(cluster) as value WHERE `vault_telemetry` by cluster</query>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </search>
      <choice value="*">all</choice>
    </input>
    <input type="multiselect" token="namespace_list" searchWhenChanged="true">
      <label>Namespace</label>
      <default>*</default>
      <initialValue>*</initialValue>
      <fieldForLabel>namespace</fieldForLabel>
      <fieldForValue>namespace_path</fieldForValue>
      <search>
        <query>| mcatalog values(namespace) AS namespace_path WHERE `vault_telemetry` AND cluster=$cluster$ BY namespace</query>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </search>
      <choice value="*">All</choice>
      <valuePrefix>"</valuePrefix>
      <valueSuffix>"</valueSuffix>
      <delimiter>,</delimiter>
      <change>
        <condition label="All">
          <set token="namespace_title"></set>
        </condition>
        <condition match="len($namespace_list$) &gt; 0">
          <set token="namespace_title">, in namespaces $namespace_list$</set>
        </condition>
      </change>
    </input>
    <input type="dropdown" token="timeseries_by">
      <label>Token timeseries to plot</label>
      <choice value="namespace">Namespaces</choice>
      <choice value="auth_method">Auth methods</choice>
      <choice value="mount_point">Mount point</choice>
      <choice value="policy">Policies</choice>
      <choice value="creation_ttl">Creation TTLs</choice>
      <default>namespace</default>
      <change>
        <condition value="namespace">
          <set token="show_namespace_timeseries">1</set>
          <unset token="show_auth_method_timeseries"></unset>
          <unset token="show_mount_point_timeseries"></unset>
          <unset token="show_policy_timeseries"></unset>
          <unset token="show_ttl_timeseries"></unset>
          <set token="has_creation_count">1</set>
        </condition>
        <condition value="auth_method">
          <unset token="show_namespace_timeseries"></unset>
          <set token="show_auth_method_timeseries">1</set>
          <unset token="show_mount_point_timeseries"></unset>
          <unset token="show_policy_timeseries"></unset>
          <unset token="show_ttl_timeseries"></unset>
          <set token="has_creation_count">1</set>
        </condition>
        <condition value="mount_point">
          <unset token="show_namespace_timeseries"></unset>
          <unset token="show_auth_method_timeseries"></unset>
          <set token="show_mount_point_timeseries">1</set>
          <unset token="show_policy_timeseries"></unset>
          <unset token="show_ttl_timeseries"></unset>
          <set token="has_creation_count">1</set>
        </condition>
        <condition value="policy">
          <unset token="show_namespace_timeseries"></unset>
          <unset token="show_auth_method_timeseries"></unset>
          <unset token="show_mount_point_timeseries"></unset>
          <set token="show_policy_timeseries">1</set>
          <unset token="show_ttl_timeseries"></unset>
          <unset token="has_creation_count"></unset>
        </condition>
        <condition value="creation_ttl">
          <unset token="show_namespace_timeseries"></unset>
          <unset token="show_auth_method_timeseries"></unset>
          <unset token="show_mount_point_timeseries"></unset>
          <unset token="show_policy_timeseries"></unset>
          <set token="show_ttl_timeseries">1</set>
          <set token="has_creation_count">1</set>
        </condition>
      </change>
    </input>
    <input type="multiselect" token="auth_method_list" searchWhenChanged="true"  depends="$has_creation_count$">
      <label>Auth method</label>
      <choice value="*">All</choice>
      <default>*</default>
      <initialValue>*</initialValue>
      <fieldForLabel>auth_method</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query>| mcatalog values(auth_method) AS value WHERE `vault_telemetry` AND cluster=$cluster$ BY auth_method</query>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </search>
      <valuePrefix>"</valuePrefix>
      <valueSuffix>"</valueSuffix>
      <delimiter> ,</delimiter>
      <change>
        <condition label="All">
          <set token="auth_method_title"></set>
        </condition>
        <condition match="len($auth_method_list$) &gt; 0">
          <set token="auth_method_title">, with auth methods $auth_method_list$</set>
        </condition>
      </change>
    </input>
    <input type="multiselect" token="mount_point_list" searchWhenChanged="true" depends="$has_creation_count$">
      <label>Mount point</label>
      <choice value="*">All</choice>
      <default>*</default>
      <initialValue>*</initialValue>
      <fieldForLabel>mount_point</fieldForLabel>
      <fieldForValue>path</fieldForValue>
      <search>
        <query>| mcatalog values(mount_point) AS path WHERE `vault_telemetry` AND cluster=$cluster$ BY mount_point</query>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </search>
      <valuePrefix>"</valuePrefix>
      <valueSuffix>"</valueSuffix>
      <delimiter> ,</delimiter>
      <change>
        <condition label="All">
          <set token="mount_point_title"></set>
        </condition>
        <condition match="len($mount_point_list$) &gt; 0">
          <set token="mount_point_title">, from mount points $mount_point_list$</set>
        </condition>
      </change>
    </input>
    <input type="multiselect" token="creation_ttl_list" searchWhenChanged="true"  depends="$has_creation_count$">
      <label>Creation TTL</label>
      <choice value="*">All</choice>
      <choice value="1m">&lt;= 1  minute</choice>
      <choice value="10m">1-10 minutes</choice>
      <choice value="20m">10-20 minutes</choice>
      <choice value="1h">20m-1 hour</choice>
      <choice value="2h">1-2 hours</choice>
      <choice value="1d">2h- 1 day</choice>
      <choice value="2d">1-2 days</choice>
      <choice value="7d">2-7 days</choice>
      <choice value="30d">7-30 days</choice>
      <choice value="'+Inf'">longer</choice>
      <default>*</default>
      <initialValue>*</initialValue>
      <delimiter>, </delimiter>
      <change>
        <condition label="All">
          <set token="creation_ttl_title"></set>
        </condition>
        <condition match="len($creation_ttl_list$) &gt; 0">
          <set token="creation_ttl_title">, with TTLs $creation_ttl_list$</set>
        </condition>
      </change>
    </input>
    <input type="dropdown" token="token_type" searchWhenChanged="true"  depends="$has_creation_count$">
      <label>Token Type</label>
      <choice value="*">All</choice>
      <choice value="service">Service</choice>
      <choice value="batch">Batch</choice>
      <default>*</default>
      <change>
        <condition value="service">
          <set token="token_type_title">Service tokens</set>
        </condition>
        <condition value="batch">
          <set token="token_type_title">Batch tokens</set>
        </condition>
        <condition value="*">
          <set token="token_type_title">Tokens</set>
        </condition>
      </change>
    </input>
    <!-- policy selection only works on the policy count metric; it's not part of vault.token.creation metric label set -->
    <input type="multiselect" token="policy_list" searchWhenChanged="true" depends="$show_policy_timeseries$">
      <label>Policy</label>
      <choice value="*">All</choice>
      <default>*</default>
      <initialValue>*</initialValue>
      <fieldForLabel>policy</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query>| mcatalog values(policy) AS value WHERE `vault_telemetry` AND cluster=$cluster$ BY policy</query>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </search>
      <valuePrefix>"</valuePrefix>
      <valueSuffix>"</valueSuffix>
      <delimiter> ,</delimiter>
    </input>
   <input type="multiselect" token="secret_engine_list" searchWhenChanged="true">
      <label>Secrets engine (leases only)</label>
      <choice value="*">All</choice>
      <initialValue>*</initialValue>
      <fieldForLabel>secret_engine</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query>| mcatalog values(secret_engine) AS value WHERE `vault_telemetry` AND cluster=* BY secret_engine</query>
        <earliest>-30d@d</earliest>
        <latest>now</latest>
      </search>
      <default>*</default>
      <valuePrefix></valuePrefix>
      <valueSuffix></valueSuffix>
      <delimiter> ,</delimiter>
      <change>
        <condition label="All">
          <set token="secret_engine_title"></set>
        </condition>
        <condition match="len($secret_engine_list$) &gt; 0">
          <set token="secret_engine_title">, from secret engines $secret_engine_list$</set>
        </condition>
      </change>
    </input>
  </fieldset>
  <row>
    <panel>
      <html>
      <style>
        .dashboard-row .dashboard-panel .panel-body.html {
          background: #f2f4f5;
          padding-top: 20px;
          padding-bottom: 0;
        }
      </style>
      <h2>Policies &amp; Tokens</h2>
    </html>
    </panel>
  </row>
  <row depends="$show_namespace_timeseries$">
    <panel>
      <title>$token_type_title$ created$auth_method_title$$mount_point_title$$creation_ttl_title$</title>
      <chart>
        <title>By namespace</title>
        <search>
          <!-- vault.token.creation -->
          <!-- Filters by cluster, namespace, auth_method, mount_point, creation_ttl, auth_entity, policies, token type -->
          <query>| mstats sum(vault.token.creation.value) AS tokens WHERE `vault_telemetry` AND cluster=$cluster$ AND namespace IN ($namespace_list$) AND mount_point IN ($mount_point_list$) AND auth_method IN ($auth_method_list$) AND creation_ttl IN ($creation_ttl_list$) AND token_type=$token_type$ BY namespace span=1m
| timechart bins=1000 sum(tokens) by namespace
| addtotals row=true</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.visibility">collapsed</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">zero</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">right</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">250</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <title>Total number of service tokens</title>
      <chart>
        <title>By namespace</title>
        <search>
          <!-- vault.token.count -->
          <!-- Filters by cluster, namespace -->
          <!-- sum over clusters, plot by namespace -->
          <query>| mstats latest(vault.token.count.value) AS tokens WHERE `vault_telemetry` AND cluster=$cluster$ AND namespace IN ($namespace_list$)  BY cluster,namespace span=10m
| stats sum(tokens) as tokens by _time,namespace
| timechart bins=1000 latest(tokens) by namespace
| addtotals row=true</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>5m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">45</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">right</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">250</option>
        <option name="refresh.display">none</option>
      </chart>
    </panel>
  </row>
  <row depends="$show_namespace_timeseries$">
    <panel>
      <title>Tokens by auth method$namespace_title$</title>
      <!-- vault.token.count.by_auth -->
      <!-- Filters by cluster, namespace -->
      <chart id="tokens_by_auth_method">
        <search>
          <query>| mstats latest(vault.token.count.by_auth.value) as count where `vault_telemetry` AND cluster=$cluster$ AND namespace IN ($namespace_list$) by cluster,namespace,auth_method span=10m
| stats sum(count) as count by _time,auth_method
| eventstats latest(_time) as latesttime
| where _time == latesttime
| stats max(count) as count by auth_method</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>5m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <title>Tokens by policy$namespace_title$</title>
      <!-- vault.token.count.by_policy -->
      <!-- Filters by cluster, namespace -->
      <chart id="tokens_by_policy">
        <search>
          <query>| mstats latest(vault.token.count.by_policy.value) as count where `vault_telemetry` AND cluster=$cluster$ AND namespace IN ($namespace_list$) by cluster,namespace,policy span=10m
| stats sum(count) as count by _time,policy
| eventstats latest(_time) as latesttime
| where _time == latesttime
| append [makeresults 1 | eval policy="root", count=0]
| stats max(count) as num_tokens by policy
| eval root_count=if(policy=="root",num_tokens,0), count=if(policy=="root",0,num_tokens), is_root=if(policy=="root",1,0)
| sort -is_root, -num_tokens
| head 12
| sort -num_tokens 
| fields - num_tokens is_root</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>5m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.axisTitleX.visibility">collapsed</option>
        <option name="charting.axisTitleY.visibility">collapsed</option>
        <option name="charting.chart">bar</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.fieldColors">{"count":0x1563ff, "root_count":0xc73445}</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">none</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_self">/app/vault/report?s=Token%20counts%20details</link>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>Tokens by TTL$namespace_title$</title>
      <!-- vault.token.count.by_ttl -->
      <!-- Filters by cluster, namespace -->
      <chart id="tokens_by_ttl">
        <search>
          <query>| mstats latest(vault.token.count.by_ttl.value) as count where `vault_telemetry` AND cluster=$cluster$ AND namespace IN ($namespace_list$) by cluster,namespace,creation_ttl span=10m
| stats sum(count) as count by _time,creation_ttl
| eventstats latest(_time) as latesttime
| where _time == latesttime
| stats max(count) as count by creation_ttl</query>
          <earliest>$timerange.earliest$</earliest>
          <latest>$timerange.latest$</latest>
          <refresh>5m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.seriesColors">[0x1563ff, 0x25BA81, 0xfac402, 0xc73445, 0x5c4ee5, 0x00BBFF, 0x2EB039, 0xfa8f37, 0xc62a71]</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row depends="$show_auth_method_timeseries$">
    <panel>
      <title>$token_type_title$ created$namespace_title$$mount_point_title$$creation_ttl_title$</title>
